# --- Bangalore-or-bust configuration ---
# Copy to .env (or export these in your shell / systemd unit) and fill in.

# Anthropic API key for the vision LLM that reads the treadmill display
# and generates town facts. https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Google Maps key. Needs: Maps JavaScript API, Street View Static API,
# and Geocoding API enabled. Used both client-side (pano + mini-map) and
# server-side (screenshots + reverse geocoding).
GOOGLE_MAPS_API_KEY=AIza...

# Serial port the ESP32-CAM is connected to.
#   Pi GPIO UART: /dev/serial0     USB adapter: /dev/ttyUSB0
SERIAL_PORT=/dev/serial0
SERIAL_BAUD=115200

# Vision/text model. Cheap + good with images.
LLM_MODEL=claude-haiku-4-5

# How often (seconds) to capture + read the display and update position.
UPDATE_INTERVAL_SEC=60

# Treadmill distance units: "miles" or "km".
DISTANCE_UNIT=miles

# Dev flags: run the whole loop + UI without hardware or API calls.
# FAKE_SERIAL reads JPEGs from samples/ instead of the ESP32.
# FAKE_LLM returns canned readings instead of calling Anthropic.
FAKE_SERIAL=0
FAKE_LLM=0
